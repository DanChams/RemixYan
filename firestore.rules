rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Pour l'instant, on autorise tout utilisateur connecté à éditer (pour le dev)
      // On pourra restreindre par email plus tard
      return isSignedIn();
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() > 0 &&
             data.category is string &&
             data.imageUrl is string;
    }

    match /projects/{projectId} {
      allow read: if true; // Public access to view projects
      allow create: if isAdmin() && isValidProject(request.resource.data);
      allow update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
